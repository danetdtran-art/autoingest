# Fly / production
# App can listen on 8080 internally. Fly routes external 80/443 to this internal port.
AUTOINGEST_PORT=8080
AUTOINGEST_DB_PATH=/data/history.db
AUTOINGEST_UPLOAD_DIR=/data/uploads
AUTOINGEST_LLM_BASE_URL=https://YOUR-PROD-LLM-ENDPOINT/v1
AUTOINGEST_LLM_MODEL=YOUR-PROD-MODEL
AUTOINGEST_MAX_FILE_SIZE_MB=50
AUTOINGEST_LLM_API_KEY=YOUR_SECRET_KEY
